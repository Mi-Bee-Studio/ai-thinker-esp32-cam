menu "mibee-cam Configuration"

    config MIBEE_CAM_ENABLE_MOTION
        bool "Enable motion detection"
        default y
        help
            Enable frame-difference motion detection.

    config MIBEE_CAM_ENABLE_NAS
        bool "Enable NAS upload (FTP/WebDAV/HTTP)"
        default y
        help
            Enable file upload to NAS server via FTP, WebDAV, or HTTP POST.

    config MIBEE_CAM_ENABLE_HEALTH
        bool "Enable health monitoring"
        default y
        help
            Enable periodic health monitoring with Prometheus /metrics endpoint.

    config MIBEE_CAM_DEFAULT_XCLK_MHZ
        int "Default camera XCLK frequency (MHz)"
        default 20
        help
            Master clock frequency for the camera sensor.
            20 MHz is standard for genuine OV2640.
            Use 10 MHz for unstable clone modules (fixes NO-SOI / white image).
            The user can override at runtime via web UI.

endmenu
